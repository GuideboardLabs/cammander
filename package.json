{
  "name": "cammander",
  "version": "1.0.0",
  "private": true,
  "description": "A workspace-native AI coding harness. Claude Code for the Ollama ecosystem.",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build:shared && npm run build:backend && npm run build:frontend",
    "build:shared": "tsc -p shared/tsconfig.json",
    "build:backend": "npm run build --workspace=apps/backend",
    "build:frontend": "npm run build --workspace=apps/frontend",
    "dev": "concurrently \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "npm run start:dev --workspace=apps/backend",
    "dev:frontend": "npm run start --workspace=apps/frontend",
    "lint": "eslint .",
    "test": "npm run test --workspace=apps/backend && npm run test --workspace=apps/frontend"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "typescript": "~5.6.0"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "http-proxy": "^1.18.1"
  }
}
